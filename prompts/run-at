#!/bin/bash
# 次の一回だけ実行時間を上書きするコマンド
# 使い方:  run-at 04:30
#          run-at "2026-04-24 04:30"
#          run-at now        （即時実行）

set -euo pipefail

TIME="${1:-}"
if [ "$TIME" = "--help" ] || [ "$TIME" = "-h" ] || [ -z "$TIME" ]; then
  echo "使い方: $(basename "$0") <HH:MM>  例: $(basename "$0") 04:30" >&2
  echo "        $(basename "$0") now       （即時実行）" >&2
  exit 1
fi

SCRIPT="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/run-prompts.sh"
export PATH="/home/sera/.config/nvm/versions/node/v20.20.2/bin:$PATH"

if [ "$TIME" = "now" ]; then
  # 即時実行
  systemd-run --user --on-active=1s --description="Claude prompts (one-shot)" "$SCRIPT"
  echo "即時実行をスケジュールしました"
elif [[ "$TIME" =~ ^[0-9]{1,2}:[0-9]{2}$ ]]; then
  # HH:MM 形式 → 今日まだその時刻を過ぎていなければ今日、過ぎていれば明日
  CALENDAR="*-*-* ${TIME}:00"
  systemd-run --user --on-calendar="$CALENDAR" --description="Claude prompts (one-shot)" "$SCRIPT"
  echo "スケジュール: 次の ${TIME} に一回だけ実行"
else
  # "YYYY-MM-DD HH:MM" などフル指定
  systemd-run --user --on-calendar="$TIME" --description="Claude prompts (one-shot)" "$SCRIPT"
  echo "スケジュール: $TIME に一回だけ実行"
fi

echo ""
echo "--- 現在のタイマー一覧 ---"
systemctl --user list-timers --no-pager
